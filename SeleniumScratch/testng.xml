<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="EcommerceSuite" parallel="none">

    <listeners>
        <listener class-name="SylviaAcademy.resources.Listeners"/>
    </listeners>

    <test name="LoginTests">
        <classes>
            <class name="SylviaAcademy.tests.LoginTest"/>
        </classes>
    </test>

    <test name="DashboardTests">
        <classes>
            <class name="SylviaAcademy.tests.ResearchTest"/>
        </classes>
    </test>

    <test name="OrderTests">
        <classes>
            <class name="SylviaAcademy.tests.SubmitOrderTest"/>
        </classes>
    </test>

</suite>
